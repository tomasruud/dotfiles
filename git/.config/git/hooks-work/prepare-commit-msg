#!/usr/bin/env janet

(use judge)
(use spork/sh-dsl)

(defn ticket-from-branch [branch]
  (first
    (peg/match
      '{:main (+ (<- :ticket) "-" (thru -1))
        :ticket (* :project "-" :id)
        :project (some (range "AZ"))
        :id (some (range "09"))}
      branch)))

(test (ticket-from-branch "AB-1234-foo-bar") "AB-1234")
(test (ticket-from-branch "my-new-feature") nil)

(defn main [_ file & args]
  (when-let [source (get args 0 "")
             is-regular-commit? (peg/match '(+ "message" "") source)
             branch ($<_ git symbolic-ref --short HEAD)
             ticket (ticket-from-branch branch)]
    (spit file (string ticket ": " (slurp file))))

  ($ git interpret-trailers
     --if-exists addIfDifferent
     --trailer "Co-Authored-By: Claude <noreply@anthropic.com>"
     --in-place ,file))
