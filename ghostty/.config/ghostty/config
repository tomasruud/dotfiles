font-family = "Maple Mono"
font-size = 14
adjust-cell-height = 13%

title = " "
theme = dark:ttox-dark,light:ttox-light

mouse-hide-while-typing = true
scrollback-limit = 1000000
window-save-state = always

keybind = super+left=goto_split:left
keybind = super+down=goto_split:bottom
keybind = super+up=goto_split:top
keybind = super+right=goto_split:right
keybind = super+f=goto_split:previous

keybind = super+h=new_split:left
keybind = super+j=new_split:down
keybind = super+k=new_split:up
keybind = super+l=new_split:right

keybind = super+z=toggle_split_zoom

