#!/bin/bash

files=(
    "$HOME/.ssh/config"
    "$HOME/.ssh/known_hosts"
    "$HOME/.netrc"
    "$HOME"/.env*
    "$HOME/.gitconfig.local"
    "$HOME/AGENTS.md"
    "$HOME/.zsh_history"
    "$HOME/.usql_history"
    "$HOME/notes.md"
    "$HOME/.pgpass"
    "$HOME/.pg_service.conf"
    "$HOME"/.psql_history*
    "$HOME/.aws/config"
)

existing=()
for f in "${files[@]}"; do
    [ -e "$f" ] && existing+=("$f")
done

tar -zcvf "$HOME/dotfiles/$(hostname)-$(date +%Y-%m-%d)-secrets.backup.tgz" "${existing[@]}"
