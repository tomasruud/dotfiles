{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash",
      "Edit",
      "Write",
      "Read"
    ],
    "deny": [
      "Agent",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "statusLine": {
    "type": "command",
    "command": "janet ~/.claude/statusline.janet"
  },
  "prefersReducedMotion": true,
  "autoMemoryDirectory": "~/.claude-private/memory",
  "skipDangerousModePermissionPrompt": true,
  "theme": "light",
  "agentPushNotifEnabled": true
}
